{
  "name": "@falcon/sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for integrating partner applications with FALCON Connect",
  "license": "UNLICENSED",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./effect": {
      "types": "./dist/effect/index.d.ts",
      "import": "./dist/effect/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "https://npm.d-zwei.de/"
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "tsdown",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "effect": "^3.21.0",
    "zod": "^4.3.6"
  }
}
