{
  "name": "connect",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/node": "^22.13.14",
      "@cloudflare/workers-types": "^4.20251213.0",
      "hono": "^4.8.2",
      "@orpc/server": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "better-auth": "1.5.5",
      "alchemy": "^0.87.0",
      "wrangler": "^4.54.0",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "@libsql/client": "0.15.15",
      "libsql": "0.5.22",
      "@orpc/client": "^1.12.2",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "nx run-many -t dev",
    "build": "nx run-many -t build",
    "check-types": "nx run-many -t check-types",
    "typecheck": "bun run check-types",
    "dev:web": "nx run-many -t dev --projects=@falcon/connect-dashboard",
    "dev:server": "nx run-many -t dev --projects=@falcon/connect-server",
    "dev:docs": "nx run-many -t dev --projects=@falcon/connect-docs",
    "dev:demo-01": "nx run-many -t dev --projects=@falcon/connect-demo-01",
    "dev:demo-02": "nx run-many -t dev --projects=@falcon/connect-demo-02",
    "dev:demo-all": "bun run dev:demo-01 && bun run dev:demo-02",
    "db:push": "nx run-many -t db:push --projects=@falcon/db",
    "db:studio": "nx run-many -t db:studio --projects=@falcon/db",
    "db:generate": "nx run-many -t db:generate --projects=@falcon/db",
    "db:migrate": "nx run-many -t db:migrate --projects=@falcon/db",
    "db:local": "nx run-many -t db:local --projects=@falcon/db",
    "deploy": "nx run-many -t deploy --projects=@falcon/infra",
    "destroy": "nx run-many -t destroy --projects=@falcon/infra",
    "check": "oxlint && oxfmt --write",
    "format": "oxfmt --write",
    "lint": "oxlint",
    "test": "nx run-many -t test",
    "prepare": "effect-language-service patch"
  },
  "dependencies": {
    "@effect/platform": "^0.96.0",
    "@falcon/env": "workspace:*",
    "dotenv": "catalog:",
    "effect": "^3.21.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@effect/language-service": "^0.82.0",
    "@falcon/config": "workspace:*",
    "@types/node": "catalog:",
    "lefthook": "^2.0.13",
    "nx": "^21.5.2",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.9"
}
